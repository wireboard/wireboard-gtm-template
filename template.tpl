___SANDBOXED_JS_FOR_WEB_TEMPLATE___

// Sandboxed APIs
const callInWindow = require('callInWindow');
const copyFromWindow = require('copyFromWindow');
const createArgumentsQueue = require('createArgumentsQueue');
const createQueue = require('createQueue');
const injectScript = require('injectScript');
const log = require('logToConsole');
const makeNumber = require('makeNumber');

const WIREBOARD_JS = 'https://static.wireboard.io/wireboard.js';
const EVENTS_JS = 'https://static.wireboard.io/events.min.js';

const fail = (msg) => {
  log('WireBoard GTM: ' + msg);
  return data.gtmOnFailure();
};

// ----- Custom Event mode -----
if (data.type === 'event') {
  const wireboardEvent = copyFromWindow('wireboardEvent');
  if (!wireboardEvent) {
    return fail('wireboardEvent is not available. Make sure the WireBoard Initialization tag has fired first.');
  }

  // Build props from the table, drop empty rows
  let props = null;
  if (data.props && data.props.length > 0) {
    props = {};
    for (let i = 0; i < data.props.length; i++) {
      const row = data.props[i];
      if (row.key && row.value !== undefined && row.value !== '') {
        props[row.key] = row.value;
      }
    }
  }

  const payload = {
    category: data.category,
    action: data.action
  };
  if (data.label) payload.label = data.label;
  if (data.value !== undefined && data.value !== '') {
    const n = makeNumber(data.value);
    payload.value = n;
  }
  if (props) payload.props = props;

  callInWindow('wireboardEvent', payload);
  return data.gtmOnSuccess();
}

// ----- Initialization mode -----

// Set up the wireboard queue stub if the SDK has not loaded yet.
// The install snippet's IIFE does three things:
//   1. push 'wireboard' into WireBoardNamespace (so the SDK bootstraps our namespace)
//   2. create window.wireboard as the queue function
//   3. initialize window.wireboard.q as an empty array
// createArgumentsQueue handles #2 and #3. We must do #1 ourselves.
const existing = copyFromWindow('wireboard');
if (!existing) {
  const registerNamespace = createQueue('WireBoardNamespace');
  registerNamespace('wireboard');
  createArgumentsQueue('wireboard', 'wireboard.q');
}

// Queue the tracker config calls. They will be drained when wireboard.js loads
// and the SDK swaps wireboard.q from an array to a dispatcher.
const trackerOpts = {
  appId: data.siteId,
  forceSecureTracker: true,
  contexts: { performanceTiming: true }
};
if (data.cookieMode === 'cookieless') {
  trackerOpts.useCookies = false;
  trackerOpts.useLocalStorage = false;
}

const collectorUrl = data.collectorUrl || 'pipeline-0.collector.wireboard.io';

callInWindow('wireboard', 'newTracker', 'wb', collectorUrl, trackerOpts);

if (data.activityTracking) {
  callInWindow('wireboard', 'enableActivityTracking', 5, 10);
}

const publisherContext = [{
  schema: 'wb:io.wireboard/publisher',
  data: { publisher: data.publisherId }
}];
callInWindow('wireboard', 'trackPageView', null, publisherContext);

// Load wireboard.js, then events.min.js, then activate optional features.
// log() is only used in fail(); successful happy-path doesn't narrate itself.
const onWireboardLoaded = () => {
  injectScript(EVENTS_JS, () => {
    // wireboardSetPublisher is defined in events.min.js
    callInWindow('wireboardSetPublisher', data.publisherId);
    if (data.dataLayerCapture) {
      callInWindow('wireboardEnableDataLayerListener');
    }
    return data.gtmOnSuccess();
  }, () => {
    return fail('Failed to load events.min.js');
  });
};

injectScript(WIREBOARD_JS, onWireboardLoaded, () => {
  return fail('Failed to load wireboard.js');
});


